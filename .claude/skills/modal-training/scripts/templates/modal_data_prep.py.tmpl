"""Dataset prep on Modal — generated by the modal-training skill.

Generated for experiment: ${EXP_ID}

CPU-only container that downloads + processes a dataset and writes JSONL to
the per-experiment data volume. Customize the body of `prep()` to do whatever
your experiment needs; the lifecycle wrapping should stay as-is.

Run:
    modal run --env=neurico-${EXP_ID} <this file> \\
        2>&1 | tee logs/modal_data_prep_$$(date +%Y%m%d_%H%M%S).log
"""
from __future__ import annotations

import json
import os
import sys
from datetime import datetime, timezone
from pathlib import Path

import modal

# lifecycle.py only exists in the local workspace; if the import fails we're
# inside the Modal container. See lora-train template for the rationale.

EXP_ID      = "${EXP_ID}"
DATA_VOLUME = "${DATA_VOLUME}"

try:
    sys.path.insert(0, str(Path(".claude/skills/modal-training/scripts")))
    import lifecycle  # noqa: E402
except ImportError:
    lifecycle = None  # type: ignore[assignment]

if lifecycle is not None:
    PULL_MANIFEST = [
        {"from_volume": DATA_VOLUME, "from": "/stats.json",
         "to": "data/stats.json",        "required": False},
        {"from_volume": DATA_VOLUME, "from": "/train.jsonl",
         "to": "data/train.jsonl",       "required": False},
        {"from_volume": DATA_VOLUME, "from": "/val.jsonl",
         "to": "data/val.jsonl",         "required": False},
    ]
    lifecycle.register(
        EXP_ID,
        volumes=[DATA_VOLUME],
        apps=[],
        required_secrets=${REQUIRED_SECRETS},
        pull_manifest=PULL_MANIFEST,
        share_hf_cache=${SHARE_HF_CACHE},
    )

MINUTES = 60

prep_image = (
    modal.Image.debian_slim(python_version="3.11")
    .uv_pip_install(
        "datasets>=2.18,<4",
        "transformers>=4.40,<5",
        "huggingface_hub[hf_transfer]",
        "pyarrow",
    )
    .env({
        "HF_HUB_ENABLE_HF_TRANSFER": "1",
        "HF_DATASETS_TRUST_REMOTE_CODE": "1",
    })
)

data_vol = modal.Volume.from_name(DATA_VOLUME, create_if_missing=True)

app = modal.App("${APP_NAME}")


@app.function(
    image=prep_image,
    cpu=4.0,
    memory=8192,
    timeout=2 * 60 * MINUTES,
    secrets=${SECRETS_LIST},
    volumes={"/data": data_vol},
)
def prep() -> dict:
    """Download, tokenize, and write JSONL into /data.

    Customize the body. The stats.json contract at the bottom is required
    (the skill's pull_all() looks for it).
    """
    from datasets import load_dataset

    Path("/data").mkdir(parents=True, exist_ok=True)

    # Example body — REPLACE with your dataset of choice.
    # The default loads a tiny sample of databricks/dolly so the template runs
    # end-to-end without modification; swap for your actual data source.
    ds = load_dataset("databricks/databricks-dolly-15k", split="train[:500]")

    train_path = "/data/train.jsonl"
    val_path   = "/data/val.jsonl"
    with open(train_path, "w", encoding="utf-8") as ft, \
         open(val_path,   "w", encoding="utf-8") as fv:
        for i, row in enumerate(ds):
            msg = [
                {"role": "user",      "content": row["instruction"]},
                {"role": "assistant", "content": row["response"]},
            ]
            sink = fv if i % 20 == 0 else ft
            sink.write(json.dumps({"messages": msg}) + "\n")

    train_rows = sum(1 for _ in open(train_path, encoding="utf-8"))
    val_rows   = sum(1 for _ in open(val_path,   encoding="utf-8"))

    stats = {
        "exp_id": "${EXP_ID}",
        "train_path": train_path,
        "val_path":   val_path,
        "train_rows": train_rows,
        "val_rows":   val_rows,
        "prepared_at": datetime.now(timezone.utc).isoformat(timespec="seconds"),
    }
    with open("/data/stats.json", "w", encoding="utf-8") as fh:
        json.dump(stats, fh, indent=2)

    data_vol.commit()
    return stats


@app.local_entrypoint()
def main():
    try:
        stats = prep.remote()
        print(json.dumps(stats, indent=2))
        print()
        print("pulling stats to workspace ...")
        pulled = lifecycle.pull_all(EXP_ID)
        print(f"pulled {len(pulled['pulled'])} items")
    finally:
        try:
            result = lifecycle.teardown(EXP_ID)
            print(f"teardown: {result}")
        except RuntimeError as exc:
            print(f"teardown skipped: {exc}", file=sys.stderr)
