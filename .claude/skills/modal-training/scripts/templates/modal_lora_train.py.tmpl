"""LoRA SFT on Modal — generated by the modal-training skill.

Generated for experiment: ${EXP_ID}

Run:
    modal run --env=neurico-${EXP_ID} <this file> \\
        2>&1 | tee logs/modal_lora_train_$$(date +%Y%m%d_%H%M%S).log

After the run, artifacts land in workspace/artifacts/. The Modal environment
neurico-${EXP_ID} is destroyed at end of run; nothing persists cloud-side.
"""
from __future__ import annotations

import json
import os
import sys
from pathlib import Path

import modal

# --------------------------------------------------------------------------- #
# Skill-provided lifecycle (register / pull_all / teardown)                   #
# --------------------------------------------------------------------------- #
#
# lifecycle.py lives at .claude/skills/modal-training/scripts/lifecycle.py and
# is ONLY available in the local workspace where `modal run` is invoked.
# Inside the Modal container that path does not exist, so the import simply
# fails — we accept that and skip the local-only setup work. The
# @app.local_entrypoint() main() runs only locally, so when it dereferences
# `lifecycle.*` the name is bound from this same try block.

EXP_ID         = "${EXP_ID}"
DATA_VOLUME    = "${DATA_VOLUME}"
CKPT_VOLUME    = "${CKPT_VOLUME}"
HF_VOLUME      = "${HF_VOLUME}"
SHARE_HF_CACHE = ${SHARE_HF_CACHE}

try:
    sys.path.insert(0, str(Path(".claude/skills/modal-training/scripts")))
    import lifecycle  # noqa: E402
except ImportError:
    lifecycle = None  # type: ignore[assignment]

if lifecycle is not None:
    # Declare exactly what this run produces and where it should land in the
    # workspace. The lifecycle has no built-in knowledge of training shapes —
    # add/remove entries here to customize. `required=True` blocks teardown
    # if the entry can't be pulled (preserves reproducibility).
    PULL_MANIFEST = [
        {"from_volume": CKPT_VOLUME, "from": "/run_config.json",
         "to": "artifacts/run_config.json",       "required": True},
        {"from_volume": CKPT_VOLUME, "from": "/modal_run.json",
         "to": "artifacts/modal_run.json",        "required": False},
        {"from_volume": CKPT_VOLUME, "from": "/trainer_state.json",
         "to": "artifacts/training_logs/trainer_state.json",
                                                  "required": True},
        {"from_volume": CKPT_VOLUME, "from": "/final",
         "to": "artifacts/final", "is_dir": True, "required": True},
    ]
    lifecycle.register(
        EXP_ID,
        volumes=[DATA_VOLUME, CKPT_VOLUME, HF_VOLUME],
        apps=[],
        required_secrets=${REQUIRED_SECRETS},
        pull_manifest=PULL_MANIFEST,
        share_hf_cache=SHARE_HF_CACHE,
    )

# --------------------------------------------------------------------------- #
# Modal app                                                                   #
# --------------------------------------------------------------------------- #

MODEL_NAME     = "${BASE_MODEL}"
MODEL_REVISION = "${BASE_MODEL_REVISION}"
MINUTES        = 60

train_image = (
    modal.Image.from_registry("nvidia/cuda:12.4.0-devel-ubuntu22.04",
                              add_python="3.11")
    .entrypoint([])
    .apt_install("git")
    .uv_pip_install(
        "torch==2.5.1",
        "transformers==4.46.3",
        "datasets==3.1.0",
        "peft==0.13.2",
        "trl==0.12.2",
        "accelerate==1.1.1",
        "huggingface_hub[hf_transfer]",
        "sentencepiece",
        "protobuf",
    )
    .env({
        "HF_HUB_ENABLE_HF_TRANSFER": "1",
        "TOKENIZERS_PARALLELISM": "false",
    })
)

hf_cache_vol = modal.Volume.from_name(HF_VOLUME,   create_if_missing=True)
data_vol     = modal.Volume.from_name(DATA_VOLUME, create_if_missing=True)
ckpt_vol     = modal.Volume.from_name(CKPT_VOLUME, create_if_missing=True)

app = modal.App("${APP_NAME}")


@app.function(
    image=train_image,
    gpu="${GPU}",
    timeout=10 * 60 * MINUTES,
    secrets=${SECRETS_LIST},
    volumes={
        "/root/.cache/huggingface": hf_cache_vol,
        "/data":  data_vol,
        "/ckpts": ckpt_vol,
    },
)
def train(
    epochs: int = ${EPOCHS},
    lr: float = ${LR},
    rank: int = ${RANK},
    alpha: int = ${ALPHA},
    batch_size: int = ${BATCH_SIZE},
    grad_accum: int = ${GRAD_ACCUM},
    max_seq_len: int = ${MAX_SEQ_LEN},
    max_steps: int = ${MAX_STEPS},
    train_file: str = "${TRAIN_FILE}",
    val_file: str = "${VAL_FILE}",
    seed: int = 42,
) -> dict:
    """LoRA SFT; saves adapter to /ckpts/final and metrics alongside."""
    import hashlib
    import time
    from datetime import datetime, timezone

    import torch
    from datasets import load_dataset
    from transformers import AutoModelForCausalLM, AutoTokenizer
    from peft import LoraConfig, get_peft_model
    from trl import SFTTrainer, SFTConfig

    t0 = time.time()
    started_at = datetime.now(timezone.utc).isoformat(timespec="seconds")

    # Reproducibility metadata. Written BEFORE training so a crash still
    # leaves provenance behind.
    def sha256_head(path: str, n: int = 4 * 1024 * 1024) -> str:
        h = hashlib.sha256()
        with open(path, "rb") as fh:
            h.update(fh.read(n))
        return h.hexdigest()

    run_config = {
        "exp_id": "${EXP_ID}",
        "base_model": MODEL_NAME,
        "base_model_revision": MODEL_REVISION,
        "lora_rank": rank,
        "lora_alpha": alpha,
        "epochs": epochs,
        "lr": lr,
        "max_steps": max_steps,
        "batch_size": batch_size,
        "grad_accum": grad_accum,
        "max_seq_len": max_seq_len,
        "seed": seed,
        "dataset_train_path": train_file,
        "dataset_val_path": val_file,
        "started_at": started_at,
    }
    if os.path.exists(train_file):
        run_config["dataset_train_sha256_head"] = sha256_head(train_file)
    if os.path.exists(val_file):
        run_config["dataset_val_sha256_head"] = sha256_head(val_file)

    Path("/ckpts").mkdir(parents=True, exist_ok=True)
    with open("/ckpts/run_config.json", "w", encoding="utf-8") as fh:
        json.dump(run_config, fh, indent=2)
    ckpt_vol.commit()

    print(f"== LoRA SFT: {MODEL_NAME} -> /ckpts/final ==")
    print(f"  epochs={epochs} lr={lr} rank={rank} alpha={alpha}")
    print(f"  batch={batch_size} grad_accum={grad_accum} max_seq={max_seq_len}")

    torch.manual_seed(seed)

    tok = AutoTokenizer.from_pretrained(MODEL_NAME, use_fast=True)
    if tok.pad_token is None:
        tok.pad_token = tok.eos_token

    base = AutoModelForCausalLM.from_pretrained(
        MODEL_NAME,
        revision=MODEL_REVISION,
        torch_dtype=torch.bfloat16,
        device_map="auto",
        attn_implementation="sdpa",
    )
    base.config.use_cache = False
    base.gradient_checkpointing_enable(
        gradient_checkpointing_kwargs={"use_reentrant": False}
    )
    base.enable_input_require_grads()

    lora = LoraConfig(
        r=rank, lora_alpha=alpha, lora_dropout=0.05,
        bias="none", task_type="CAUSAL_LM",
        target_modules=["q_proj", "k_proj", "v_proj", "o_proj",
                        "gate_proj", "up_proj", "down_proj"],
    )
    model = get_peft_model(base, lora)
    model.print_trainable_parameters()

    ds = load_dataset("json",
                      data_files={"train": train_file, "validation": val_file})

    def format_row(row):
        return tok.apply_chat_template(
            row["messages"], tokenize=False, add_generation_prompt=False,
        )

    ds = ds.map(lambda r: {"text": format_row(r)},
                remove_columns=ds["train"].column_names)

    sft_cfg = SFTConfig(
        output_dir="/ckpts/run",
        num_train_epochs=epochs,
        max_steps=max_steps,
        per_device_train_batch_size=batch_size,
        per_device_eval_batch_size=batch_size,
        gradient_accumulation_steps=grad_accum,
        gradient_checkpointing=True,
        learning_rate=lr,
        warmup_ratio=0.03,
        lr_scheduler_type="cosine",
        logging_steps=10,
        eval_strategy="steps", eval_steps=200,
        save_strategy="steps", save_steps=500, save_total_limit=3,
        bf16=True,
        max_seq_length=max_seq_len,
        packing=False,
        dataset_text_field="text",
        seed=seed,
        report_to="none",
    )

    trainer = SFTTrainer(
        model=model, args=sft_cfg,
        train_dataset=ds["train"], eval_dataset=ds["validation"],
        processing_class=tok,
    )

    trainer.train()

    trainer.save_model("/ckpts/final")
    tok.save_pretrained("/ckpts/final")

    # Persist trainer_state.json (loss curve, eval metrics, step-by-step) to a
    # stable path so the workspace pull always finds it. HF Trainer writes it
    # only at save_steps boundaries inside /ckpts/run/checkpoint-*/; short runs
    # (e.g. smoke tests) may not hit any boundary, so we copy from whatever
    # checkpoint dir has the final state.
    import shutil
    final_state_src = None
    direct_path = Path("/ckpts/run/trainer_state.json")
    if direct_path.exists():
        final_state_src = direct_path
    else:
        ckpts = sorted(
            Path("/ckpts/run").glob("checkpoint-*"),
            key=lambda p: int(p.name.rsplit("-", 1)[-1])
                if p.name.rsplit("-", 1)[-1].isdigit() else 0,
        )
        for cand in reversed(ckpts):
            ts = cand / "trainer_state.json"
            if ts.exists():
                final_state_src = ts
                break
    if final_state_src is not None:
        shutil.copy(final_state_src, "/ckpts/trainer_state.json")
    else:
        # Fall back to building a minimal trainer_state from trainer.state.
        # This keeps the reproducibility gate happy on degenerate runs.
        with open("/ckpts/trainer_state.json", "w", encoding="utf-8") as fh:
            json.dump({
                "log_history": getattr(trainer.state, "log_history", []),
                "global_step": getattr(trainer.state, "global_step", 0),
                "epoch": getattr(trainer.state, "epoch", 0.0),
                "max_steps": getattr(trainer.state, "max_steps", 0),
            }, fh, indent=2)

    # Capture Modal run + container metadata for cross-reference back to the
    # Modal dashboard if the user wants to inspect logs later.
    modal_meta = {
        "modal_task_id": os.environ.get("MODAL_TASK_ID"),
        "modal_function_call_id": os.environ.get("MODAL_FUNCTION_CALL_ID"),
        "container_id": os.environ.get("MODAL_CONTAINER_ID"),
        "completed_at": datetime.now(timezone.utc).isoformat(timespec="seconds"),
        "elapsed_seconds": round(time.time() - t0, 1),
    }
    with open("/ckpts/modal_run.json", "w", encoding="utf-8") as fh:
        json.dump(modal_meta, fh, indent=2)

    ckpt_vol.commit()

    return {
        "adapter_path": "/ckpts/final",
        "elapsed_seconds": modal_meta["elapsed_seconds"],
        "train_rows": len(ds["train"]),
        "val_rows": len(ds["validation"]),
    }


@app.local_entrypoint()
def main():
    """Run training, then pull artifacts + teardown the env."""
    # Re-upload prep artifacts from the workspace. Data prep ran in its own
    # env that was torn down on completion (data volume cascade-deleted), so
    # this LoRA run starts against a fresh, empty data volume even when both
    # stages share the same EXP_ID. The workspace `data/` directory is the
    # source of truth between stages — push the local copies back onto the
    # volume the @app.function above expects to read from.
    #
    # Note: `remote_path` is a volume-root path, not a container path. The
    # volume is mounted at /data inside the container, so volume-root
    # /train.jsonl reads as /data/train.jsonl from train(). Writing to
    # /data/train.jsonl on the volume would land at /data/data/train.jsonl
    # in the container and miss the dataloader.
    for local_rel, remote_path in [
        ("data/train.jsonl", "/train.jsonl"),
        ("data/val.jsonl",   "/val.jsonl"),
    ]:
        if (Path(".") / local_rel).exists():
            uploaded = lifecycle.upload_to_volume(
                EXP_ID, DATA_VOLUME, local_rel, remote_path,
            )
            print(f"uploaded {uploaded['src']} -> {uploaded['volume']}{uploaded['remote']}")

    try:
        result = train.remote()
        print()
        print(f"train result: {result}")
        print()
        print("pulling artifacts to workspace/artifacts ...")
        pulled = lifecycle.pull_all(EXP_ID)
        print(f"pulled {len(pulled['pulled'])} items into "
              f"{pulled['workspace']}/artifacts/")
    finally:
        # teardown() refuses if pull_complete=False; that's intentional.
        # If a pull failed, the env stays alive and the user can recover.
        try:
            result = lifecycle.teardown(EXP_ID)
            print(f"teardown: {result}")
        except RuntimeError as exc:
            print(f"teardown skipped: {exc}", file=sys.stderr)
